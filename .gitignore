# Rust
/target
**/*.rs.bk

# Swift / SwiftPM
/swift/.build
/swift/.swiftpm
/swift/Package.resolved

# macOS
.DS_Store
.claude/worktrees/

# Generated WPT coverage report + per-test result store (all under one dir) and raw run logs.
/wpt-report/
/wpt-report.html
/_wpt_*.json
# Local checkout of the web-platform-tests suite (cloned for conformance runs)
/wpt/
dist/

# tc39/test262 conformance suite (cloned on demand by scripts/test262-clone.sh) + its score report.
/test262/
/test262-report/

# Scratch area lists generated for wpt-run-missing.sh (local, per-run)
/scripts/.missing_areas.txt
/scripts/.remaining_areas.txt

# Local review / analysis notes (maintainer reviews, investigation docs, etc.)
# These are not part of the source and should stay out of the public history.
review-*.md
*-review*.md
review_*.md
